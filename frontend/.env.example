# ==================== Environment ====================
# Available options: development, staging, production, test
NODE_ENV=development

# ==================== Application Configuration ====================
REACT_APP_NAME=Affiliate Platform
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION="Complete Affiliate Marketing Platform"
REACT_APP_URL=http://localhost:3000

# ==================== API Configuration ====================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000
REACT_APP_API_VERSION=v1
REACT_APP_API_TIMEOUT=30000
REACT_APP_UPLOAD_TIMEOUT=60000
REACT_APP_RETRY_ATTEMPTS=3
REACT_APP_RETRY_DELAY=1000

# ==================== Authentication ====================
REACT_APP_TOKEN_KEY=auth_token
REACT_APP_REFRESH_TOKEN_KEY=refresh_token
REACT_APP_USER_KEY=auth_user
REACT_APP_SESSION_TIMEOUT=3600
REACT_APP_REFRESH_INTERVAL=900
REACT_APP_MAX_LOGIN_ATTEMPTS=5
REACT_APP_LOCKOUT_DURATION=1800
REACT_APP_PASSWORD_MIN_LENGTH=8
REACT_APP_PASSWORD_MAX_LENGTH=128

# ==================== OAuth Providers ====================
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
REACT_APP_FACEBOOK_APP_ID=your-facebook-app-id
REACT_APP_GITHUB_CLIENT_ID=your-github-client-id

# ==================== Payment Gateways ====================
# Stripe
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
REACT_APP_STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# PayPal
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id
REACT_APP_PAYPAL_MODE=sandbox

# Razorpay
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# ==================== Currency Configuration ====================
REACT_APP_DEFAULT_CURRENCY=USD
REACT_APP_SUPPORTED_CURRENCIES=USD,EUR,GBP,INR,JPY,CNY,AUD,CAD,SGD,AED

# ==================== Payment Limits ====================
REACT_APP_MINIMUM_DEPOSIT=10
REACT_APP_MINIMUM_WITHDRAWAL=10
REACT_APP_MAXIMUM_WITHDRAWAL=10000
REACT_APP_TRANSACTION_FEE_PERCENTAGE=2.9
REACT_APP_TRANSACTION_FEE_FIXED=0.3
REACT_APP_WITHDRAWAL_FEE=1.0

# ==================== Affiliate Configuration ====================
REACT_APP_DEFAULT_COMMISSION_RATE=10
REACT_APP_MIN_COMMISSION_RATE=1
REACT_APP_MAX_COMMISSION_RATE=50
REACT_APP_COOKIE_DURATION=30
REACT_APP_MINIMUM_PAYOUT=10
REACT_APP_REFERRAL_LEVELS=3

# Level-based commission rates
REACT_APP_LEVEL_1_RATE=10
REACT_APP_LEVEL_2_RATE=5
REACT_APP_LEVEL_3_RATE=2

# ==================== Feature Flags ====================
# User features
REACT_APP_FEATURE_USER_REGISTRATION=true
REACT_APP_FEATURE_USER_PROFILE=true
REACT_APP_FEATURE_USER_SETTINGS=true

# Affiliate features
REACT_APP_FEATURE_AFFILIATE_DASHBOARD=true
REACT_APP_FEATURE_AFFILIATE_LINKS=true
REACT_APP_FEATURE_AFFILIATE_REFERRALS=true
REACT_APP_FEATURE_AFFILIATE_EARNINGS=true
REACT_APP_FEATURE_AFFILIATE_WITHDRAWALS=true

# Payment features
REACT_APP_FEATURE_PAYMENT_STRIPE=true
REACT_APP_FEATURE_PAYMENT_PAYPAL=true
REACT_APP_FEATURE_PAYMENT_RAZORPAY=false

# Social features
REACT_APP_FEATURE_SOCIAL_LOGIN=true
REACT_APP_FEATURE_SOCIAL_SHARE=true

# Communication features
REACT_APP_FEATURE_CHAT=true
REACT_APP_FEATURE_NOTIFICATIONS=true
REACT_APP_FEATURE_EMAIL_NOTIFICATIONS=true
REACT_APP_FEATURE_SMS_NOTIFICATIONS=false

# Analytics features
REACT_APP_FEATURE_ANALYTICS=true
REACT_APP_FEATURE_REPORTS=true

# Admin features
REACT_APP_FEATURE_ADMIN_DASHBOARD=true
REACT_APP_FEATURE_ADMIN_USERS=true
REACT_APP_FEATURE_ADMIN_AFFILIATES=true
REACT_APP_FEATURE_ADMIN_PAYMENTS=true
REACT_APP_FEATURE_ADMIN_REPORTS=true
REACT_APP_FEATURE_ADMIN_LOGS=true
REACT_APP_FEATURE_ADMIN_SYSTEM=true

# ==================== UI Configuration ====================
REACT_APP_DEFAULT_THEME=light
REACT_APP_THEMES=light,dark,system,dim,high-contrast
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_LANGUAGES=en,hi,bn,te,mr,ta,ur,gu,kn,ml,es,fr,de,zh,ja,ar
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_PAGE_SIZE_OPTIONS=10,25,50,100
REACT_APP_DEFAULT_DATE_FORMAT=MM/DD/YYYY
REACT_APP_DEFAULT_TIME_FORMAT=12h
REACT_APP_TOAST_DURATION=5000
REACT_APP_TOAST_POSITION=top-right

# ==================== Storage Configuration ====================
REACT_APP_STORAGE_PREFIX=app_
REACT_APP_DEFAULT_STORAGE=local
REACT_APP_STORAGE_EXPIRY=86400
REACT_APP_STORAGE_ENCRYPTION=false
REACT_APP_STORAGE_ENCRYPTION_KEY=your-encryption-key-here

# ==================== Monitoring Services ====================
# Sentry
REACT_APP_SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Google Analytics
REACT_APP_GA_TRACKING_ID=UA-XXXXX-Y

# LogRocket
REACT_APP_LOGROCKET_APP_ID=your-logrocket-app-id

# Hotjar
REACT_APP_HOTJAR_ID=your-hotjar-id
REACT_APP_HOTJAR_SV=6

# FullStory
REACT_APP_FULLSTORY_ORG_ID=your-fullstory-org-id

# Mixpanel
REACT_APP_MIXPANEL_TOKEN=your-mixpanel-token

# ==================== Social Media ====================
REACT_APP_SHARE_TITLE=Affiliate Platform
REACT_APP_SHARE_DESCRIPTION="Join the best affiliate marketing platform"
REACT_APP_SHARE_IMAGE=/logo512.png

# Social links
REACT_APP_FACEBOOK_PAGE=https://facebook.com/affiliateplatform
REACT_APP_TWITTER_HANDLE=@affiliateplatform
REACT_APP_INSTAGRAM_HANDLE=@affiliateplatform
REACT_APP_LINKEDIN_COMPANY=affiliateplatform
REACT_APP_YOUTUBE_CHANNEL=@affiliateplatform
REACT_APP_GITHUB_REPO=affiliateplatform

# ==================== SEO Configuration ====================
REACT_APP_SEO_TITLE="Affiliate Platform - Earn Money with Referrals"
REACT_APP_SEO_DESCRIPTION="Join our affiliate marketing platform and earn commissions by promoting products"
REACT_APP_SEO_KEYWORDS="affiliate, marketing, earn money, commissions, referrals"
REACT_APP_SEO_IMAGE=/logo512.png
REACT_APP_OG_SITE_NAME=Affiliate Platform
REACT_APP_OG_TYPE=website
REACT_APP_TWITTER_CARD=summary_large_image
REACT_APP_TWITTER_SITE=@affiliateplatform
REACT_APP_TWITTER_CREATOR=@affiliateplatform

# ==================== Performance Configuration ====================
REACT_APP_ENABLE_LAZY_LOADING=true
REACT_APP_ENABLE_IMAGE_LAZY_LOADING=true
REACT_APP_ENABLE_CACHING=true
REACT_APP_CACHE_DURATION=300
REACT_APP_ENABLE_COMPRESSION=true
REACT_APP_ENABLE_PWA=false
REACT_APP_SERVICE_WORKER_URL=/service-worker.js

# ==================== Security Configuration ====================
REACT_APP_CSP_ENABLED=false
REACT_APP_RATE_LIMIT_ENABLED=true
REACT_APP_RATE_LIMIT_MAX=100
REACT_APP_RATE_LIMIT_WINDOW=60
REACT_APP_XSS_PROTECTION_ENABLED=true
REACT_APP_CSRF_PROTECTION_ENABLED=true
REACT_APP_CORS_ENABLED=true
REACT_APP_HTTPS_ONLY=false
REACT_APP_HSTS_ENABLED=false
REACT_APP_HSTS_MAX_AGE=31536000

# ==================== Maintenance Mode ====================
REACT_APP_MAINTENANCE_MODE=false
REACT_APP_MAINTENANCE_MESSAGE="Site is under maintenance. Please check back later."

# ==================== Demo Mode ====================
REACT_APP_DEMO_MODE=false
REACT_APP_DEMO_MESSAGE="This is a demo version. Some features may be limited."

# ==================== Email Configuration ====================
REACT_APP_SUPPORT_EMAIL=support@affiliateplatform.com
REACT_APP_CONTACT_EMAIL=contact@affiliateplatform.com
REACT_APP_NOREPLY_EMAIL=noreply@affiliateplatform.com

# ==================== File Upload Configuration ====================
REACT_APP_MAX_FILE_SIZE=5242880  # 5MB in bytes
REACT_APP_MAX_IMAGE_SIZE=2097152  # 2MB in bytes
REACT_APP_MAX_FILES_COUNT=5
REACT_APP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
REACT_APP_ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# ==================== Date/Time Configuration ====================
REACT_APP_DEFAULT_TIMEZONE=America/New_York
REACT_APP_SUPPORTED_TIMEZONES=America/New_York,America/Chicago,America/Denver,America/Los_Angeles,Europe/London,Europe/Paris,Asia/Dubai,Asia/Kolkata,Asia/Singapore,Asia/Tokyo,Australia/Sydney

# ==================== Company Information ====================
REACT_APP_COMPANY_NAME="Affiliate Platform Inc."
REACT_APP_COMPANY_ADDRESS="123 Business Street, New York, NY 10001"
REACT_APP_COMPANY_PHONE="+1 (800) 123-4567"
REACT_APP_COMPANY_EMAIL="info@affiliateplatform.com"

# ==================== Legal Information ====================
REACT_APP_PRIVACY_POLICY_URL=/privacy
REACT_APP_TERMS_URL=/terms
REACT_APP_COOKIE_POLICY_URL=/cookies
REACT_APP_GDPR_COMPLIANCE=true

# ==================== Recaptcha ====================
REACT_APP_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
REACT_APP_ENABLE_RECAPTCHA=false

# ==================== Pusher (for real-time features) ====================
REACT_APP_PUSHER_APP_KEY=your-pusher-app-key
REACT_APP_PUSHER_CLUSTER=your-pusher-cluster
REACT_APP_ENABLE_PUSHER=false

# ==================== Firebase (optional) ====================
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-firebase-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
REACT_APP_ENABLE_FIREBASE=false

# ==================== Map Services ====================
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
REACT_APP_ENABLE_MAPS=false

# ==================== Weather API (optional) ====================
REACT_APP_OPENWEATHER_API_KEY=your-openweather-api-key
REACT_APP_ENABLE_WEATHER=false

# ==================== Testing Configuration ====================
REACT_APP_TEST_USER_EMAIL=test@example.com
REACT_APP_TEST_USER_PASSWORD=Test@123
REACT_APP_TEST_ADMIN_EMAIL=admin@example.com
REACT_APP_TEST_ADMIN_PASSWORD=Admin@123

# ==================== Debug Configuration ====================
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=info  # debug, info, warn, error
REACT_APP_REDUX_DEVTOOLS=true
REACT_APP_REACT_QUERY_DEVTOOLS=false

# ==================== PWA Configuration ====================
REACT_APP_PWA_NAME="Affiliate Platform"
REACT_APP_PWA_SHORT_NAME="Affiliate"
REACT_APP_PWA_THEME_COLOR="#667eea"
REACT_APP_PWA_BACKGROUND_COLOR="#ffffff"
REACT_APP_PWA_DISPLAY=standalone
REACT_APP_PWA_ORIENTATION=portrait
REACT_APP_PWA_SCOPE=/
REACT_APP_PWA_START_URL=/

# ==================== Cache Configuration ====================
REACT_APP_CACHE_NAME="affiliate-platform-v1"
REACT_APP_API_CACHE_DURATION=300  # 5 minutes
REACT_APP_STATIC_CACHE_DURATION=86400  # 24 hours

# ==================== Feature Announcements ====================
REACT_APP_ENABLE_ANNOUNCEMENTS=true
REACT_APP_ANNOUNCEMENT_URL=/announcements

# ==================== Help & Support ====================
REACT_APP_HELP_URL=/help
REACT_APP_DOCS_URL=/docs
REACT_APP_API_DOCS_URL=/api/docs
REACT_APP_STATUS_URL=/status

# ==================== External Links ====================
REACT_APP_BLOG_URL=https://blog.affiliateplatform.com
REACT_APP_COMMUNITY_URL=https://community.affiliateplatform.com
REACT_APP_DEVELOPER_URL=https://developers.affiliateplatform.com
REACT_APP_CAREERS_URL=https://careers.affiliateplatform.com

# ==================== Rate Limiting ====================
REACT_APP_RATE_LIMIT_LOGIN=5
REACT_APP_RATE_LIMIT_REGISTER=3
REACT_APP_RATE_LIMIT_PASSWORD_RESET=3
REACT_APP_RATE_LIMIT_API=100

# ==================== Session Configuration ====================
REACT_APP_SESSION_TIMEOUT_WARNING=300  # 5 minutes before timeout
REACT_APP_SESSION_EXTEND_ON_ACTIVITY=true
REACT_APP_MAX_CONCURRENT_SESSIONS=3

# ==================== Backup Configuration ====================
REACT_APP_ENABLE_AUTO_BACKUP=false
REACT_APP_BACKUP_FREQUENCY=weekly  # daily, weekly, monthly
REACT_APP_BACKUP_RETENTION_DAYS=30

# ==================== Export Configuration ====================
REACT_APP_EXPORT_FORMATS=csv,json,pdf,excel
REACT_APP_MAX_EXPORT_ROWS=10000
REACT_APP_EXPORT_TIMEOUT=120000

# ==================== Import Configuration ====================
REACT_APP_MAX_IMPORT_ROWS=5000
REACT_APP_ALLOWED_IMPORT_TYPES=csv,json
REACT_APP_IMPORT_TIMEOUT=180000

# ==================== Webhook Configuration ====================
REACT_APP_WEBHOOK_TIMEOUT=5000
REACT_APP_MAX_WEBHOOK_RETRIES=3
REACT_APP_WEBHOOK_RETRY_DELAY=1000

# ==================== Cron Job Configuration ====================
REACT_APP_CRON_CHECK_INTERVAL=60000  # 1 minute
REACT_APP_CRON_HEALTH_CHECK_INTERVAL=300000  # 5 minutes
REACT_APP_CRON_BACKUP_INTERVAL=86400000  # 24 hours
REACT_APP_CRON_CLEANUP_INTERVAL=3600000  # 1 hour

# ==================== Notification Configuration ====================
REACT_APP_NOTIFICATION_CHECK_INTERVAL=30000  # 30 seconds
REACT_APP_NOTIFICATION_SOUND_ENABLED=true
REACT_APP_NOTIFICATION_VIBRATION_ENABLED=true
REACT_APP_NOTIFICATION_DESKTOP_ENABLED=true
REACT_APP_NOTIFICATION_MAX_STACK=5
REACT_APP_NOTIFICATION_POSITION=top-right
