# ==================== Environment ====================
NODE_ENV=production

# ==================== API Configuration ====================
REACT_APP_API_URL=https://affiliateplatform2-0.onrender.com/api
REACT_APP_SOCKET_URL=https://affiliateplatform2-0.onrender.com
REACT_APP_API_VERSION=v1
REACT_APP_API_TIMEOUT=30000

# ==================== Authentication ====================
REACT_APP_TOKEN_KEY=auth_token
REACT_APP_REFRESH_TOKEN_KEY=refresh_token
REACT_APP_USER_KEY=auth_user

# ==================== Payment Gateways ====================
# Stripe
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# PayPal
REACT_APP_PAYPAL_CLIENT_ID=test

# ==================== Currency Configuration ====================
REACT_APP_DEFAULT_CURRENCY=USD

# ==================== Payment Limits ====================
REACT_APP_MINIMUM_WITHDRAWAL=10
REACT_APP_MAXIMUM_WITHDRAWAL=10000

# ==================== Affiliate Configuration ====================
REACT_APP_DEFAULT_COMMISSION_RATE=10
REACT_APP_COOKIE_DURATION=30
REACT_APP_MINIMUM_PAYOUT=10

# ==================== Feature Flags ====================
REACT_APP_FEATURE_USER_REGISTRATION=true
REACT_APP_FEATURE_AFFILIATE_DASHBOARD=true

# ==================== UI Configuration ====================
REACT_APP_DEFAULT_THEME=light
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_DEFAULT_PAGE_SIZE=10

# ==================== Company Information ====================
REACT_APP_SUPPORT_EMAIL=support@affiliateplatform.com

# ==================== Legal Information ====================
REACT_APP_PRIVACY_POLICY_URL=/privacy
REACT_APP_TERMS_URL=/terms
REACT_APP_COOKIE_POLICY_URL=/cookies

# ==================== Debug Configuration ====================
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=error
